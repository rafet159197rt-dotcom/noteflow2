{
  "name": "noteflow",
  "version": "1.0.0",
  "description": "NoteFlow PDF Annotator",
  "main": "index.js",
  "scripts": {
    "build": "echo 'Static app - no build needed'",
    "cap:init": "npx cap init NoteFlow com.noteflow.app --web-dir www",
    "cap:add": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:build": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/core": "^5.7.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0"
  }
}
